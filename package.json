{
  "name": "automad-mcp",
  "version": "1.0.0",
  "description": "MCP server for the Automad CMS documentation at automad.org",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "node --import tsx/esm src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "inspect": "npx @modelcontextprotocol/inspector npx tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "refresh:pages": "npx tsx bin/refresh-pages.ts"
  },
  "keywords": [
    "mcp",
    "automad",
    "cms",
    "documentation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "node-html-parser": "^6.1.13"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsx": "^4.19.2",
    "typescript": "^5.0.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18"
  }
}
